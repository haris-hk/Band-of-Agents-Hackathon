# --- Demo (judges): keep LLM off for deterministic checkout demo ---
# Set LIVE_LLM_ENABLED=true + MAX_RUN_USD>0 for real GitHub repositories.
LIVE_LLM_ENABLED=false
MAX_RUN_USD=0
MAX_RUN_TOKENS=4000
MAX_PROMPT_TOKENS=2500
MAX_AGENT_TOKENS=900
REQUEST_TIMEOUT_SECONDS=20

# LLM providers (required when LIVE_LLM_ENABLED=true)
AIML_API_KEY=
FEATHERLESS_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
AIML_MODEL=gpt-4o
FEATHERLESS_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# GitHub clone + PR push (required for GitHub repo mode in UI)
GITHUB_TOKEN=

# Optional GitHub App auth instead of PAT
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# Webhook verification (required when SHARED_DEPLOYMENT=true)
GITHUB_WEBHOOK_SECRET=
ENFORCE_GITHUB_WEBHOOK_SECRET=false

# API protection (required when SHARED_DEPLOYMENT=true)
INCIDENT_API_KEY=

# Shared / production deployment: enforces API key + webhook secret + Docker smoke at startup
SHARED_DEPLOYMENT=false

# Require Docker daemon at API startup (default: true when SHARED_DEPLOYMENT=true).
# Set false only for Band-only or UI-only hosts that never run repro/validate.
REQUIRE_DOCKER=

# Repo cache + run persistence
REPOS_ROOT=
RUNS_DIR=
RUNS_PERSIST=true

# Optional PR behavior for non-GitHub alerts
AUTO_PR_ENABLED=false

# CORS for frontend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Band SDK (optional separate runtime — see BAND_RUNTIME.md)
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
THENVOI_REST_URL=https://app.band.ai
